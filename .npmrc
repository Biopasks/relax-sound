# ─── npm Configuration ───────────────────────────────────────────────────────
# See: https://docs.npmjs.com/cli/v10/configuring-npm/npmrc

# Security
engine-strict=true
strict-peer-dependencies=true
audit=true
audit-level=high

# Performance
fetch-retries=3
fetch-retry-maxtimeout=60000
fetch-retry-mintimeout=10000
