# ─── Environment Variables ───────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Application
VITE_APP_TITLE=Relax Sound
VITE_APP_DESCRIPTION=Premium relaxation sound application

# API Keys (optional)
# VITE_SOME_API_KEY=your_key_here

# Vercel Analytics
# VITE_VERCEL_ANALYTICS_ID=

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ADS=false

# Enterprise Protection
# ENTITLEMENT_KEY=your_key_here
